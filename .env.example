# ---- DailyScribe environment ----
# Copy to .env.local (in apps/web) for local dev, and set these in Vercel for prod.
# NEVER commit real values. Placeholders only.

# MongoDB Atlas — dedicated DailyScribe project / free M0 cluster
MONGODB_URI="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB="dailyscribe"

# AES-256-GCM key for encrypting per-user secrets at rest (32 random bytes, base64).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SECRETS_ENCRYPTION_KEY="REPLACE_WITH_BASE64_32_BYTE_KEY"

# Auth.js (NextAuth v5)
# Generate AUTH_SECRET: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="REPLACE_WITH_RANDOM_SECRET"
# GitHub OAuth app — callback URL: https://dailyscribe.ca/api/auth/callback/github
AUTH_GITHUB_ID="REPLACE"
AUTH_GITHUB_SECRET="REPLACE"

# Vercel Cron guard — cron requests must send Authorization: Bearer ${CRON_SECRET}
# Generate: openssl rand -hex 32
CRON_SECRET="REPLACE_WITH_RANDOM_HEX"

# Resend — app-wide outbound email from the verified dailyscribe.ca domain.
# Users whitelist this ONE address in their Kindle's Approved Personal Document E-mail List.
RESEND_API_KEY="REPLACE_WITH_RESEND_API_KEY"
MAIL_FROM_DEFAULT="Daily Scribe <my@dailyscribe.ca>"
